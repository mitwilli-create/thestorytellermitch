# broll-pipeline configuration. Copy to .env and fill in. Never commit .env.
# Repo: https://github.com/mitwilli-create/broll-pipeline

# ElevenLabs API key. Get one at https://elevenlabs.io/app/settings/api-keys
# (API Pro/Scale tier for video credits).
XI_API_KEY=

# Optional: default narration voice id. List your voices with:
#   node -e "import('./lib/elevenlabs.mjs').then(m=>m.listVoices()).then(v=>console.log(v.voices.map(x=>x.name+' '+x.voice_id)))"
XI_VOICE_ID=

# Visual stage provider (pluggable adapter, lib/fal.mjs).
# Key from https://fal.ai/dashboard/keys
FAL_KEY=

# Optional: override the text-to-video model slug (defaults to lib/fal.mjs DEFAULT_SLUG).
FAL_MODEL_SLUG=

# Creative council + shot direction (lib/creative.mjs).
# Key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional: council model override.
CREATIVE_MODEL=
