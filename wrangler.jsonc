{
  // Cloudflare Workers Static Assets config for the git-connected build.
  // The site is pre-baked static files at the repo root; this serves them as
  // Workers Assets. Exclusions live in .assetsignore (same format as .gitignore).
  // There is no Worker script, so no `main` entry and no compat flags are needed.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "thestorytellermitch",
  "compatibility_date": "2026-07-10",
  "assets": {
    "directory": "."
  }
}
